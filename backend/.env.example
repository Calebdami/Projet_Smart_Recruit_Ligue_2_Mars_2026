# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartrecruit_db
DB_USER=smartrecruit_user
DB_PASSWORD=secure_password_here
DB_SSL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 2FA Configuration
TWO_FACTOR_SECRET_BASE=smartrecruit_2fa_base_secret

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@smartrecruit.com
EMAIL_FROM_NAME=SmartRecruit Team

# File Storage Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,image/webp

# S3 Configuration (Optional - for production)
S3_BUCKET=smartrecruit-files
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Webinar Configuration
WEBINAR_BASE_URL=https://your-webinar-platform.com
WEBINAR_API_KEY=
WEBINAR_API_SECRET=

# Analytics & Monitoring
LOG_LEVEL=info
SENTRY_DSN=
METRICS_ENABLED=true

# Cron Jobs Configuration
CRON_REMINDER_ENABLED=true
CRON_CLEANUP_ENABLED=true
CRON_REPORT_ENABLED=true

# Security
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
HELMET_ENABLED=true

# AI & ML Configuration
AI_SCORING_ENABLED=true
AI_MODEL_PATH=./models/scoring-model.json
SEMANTIC_SIMILARITY_THRESHOLD=0.8
